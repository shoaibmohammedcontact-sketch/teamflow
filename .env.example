# ---------------------------------------------------------------------------
# TeamFlow — Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# Database (SQLite for local dev — swap to postgresql:// for production)
DATABASE_URL="file:./db/custom.db"

# App
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Realtime mini-service (Socket.IO on port 3003)
REALTIME_PORT=3003
REALTIME_URL="http://localhost:3003"

# Email (optional — invitation flow currently generates tokens + URLs only)
# SMTP_URL="smtp://user:pass@smtp.mailtrap.io:587"
# FROM_EMAIL="TeamFlow <no-reply@teamflow.dev>"
