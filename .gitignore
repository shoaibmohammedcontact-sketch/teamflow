# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
/coverage

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
/.next/
/out/

# ---------------------------------------------------------------------------
# Production build
# ---------------------------------------------------------------------------
/build

# ---------------------------------------------------------------------------
# Environment variables (never commit secrets)
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Database (SQLite — regenerated via `bun run db:push && bun run db:seed`)
# ---------------------------------------------------------------------------
/db/*.db
/db/*.db-journal
/db/*.db-wal
/db/*.db-shm

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log
realtime.log

# ---------------------------------------------------------------------------
# Platform / editor
# ---------------------------------------------------------------------------
.DS_Store
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp

# ---------------------------------------------------------------------------
# Local-only files
# ---------------------------------------------------------------------------
local-*
.claude
.z-ai-config
prompt
test

# ---------------------------------------------------------------------------
# Vercel
# ---------------------------------------------------------------------------
.vercel

# ---------------------------------------------------------------------------
# TypeScript build cache
# ---------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Sandbox-only artefacts (not part of the project)
# ---------------------------------------------------------------------------
/skills/
/.zscripts/
/upload/
/download/
